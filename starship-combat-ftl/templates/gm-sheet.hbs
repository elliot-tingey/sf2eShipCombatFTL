{{!-- ═══════════════════════════════════════════════════════════════════════
     STARSHIP COMBAT — FTL EDITION v3.1 — GM Sheet
     Layout: PF2e-style sidebar + tabbed main content
     ═══════════════════════════════════════════════════════════════════════ --}}

<div class="sc-gm-sheet">

  {{!-- ─── SIDEBAR ─────────────────────────────────────────────────────── --}}
  <aside class="sc-sidebar">

    {{!-- Portrait --}}
    <div class="sc-sidebar-portrait">
      <img src="{{img}}" alt="{{name}}" data-action="pickImage" title="Click to change image" />
      <div class="sc-portrait-hover"><i class="fa-solid fa-image"></i></div>
    </div>

    {{!-- Name & Tags --}}
    <div class="sc-sidebar-identity">
      <input type="text" class="sc-sidebar-name" data-field="name" value="{{data.name}}" placeholder="Ship Name" />
      <div class="sc-sidebar-tags">
        <span class="sc-tag sc-tag-size">{{data.size}}</span>
        <span class="sc-tag sc-tag-frame">{{data.frame}}</span>
        <span class="sc-tag sc-tag-disposition {{data.disposition}}">{{data.disposition}}</span>
      </div>
    </div>

    {{!-- AC / TL Defense Boxes --}}
    <div class="sc-sidebar-defenses">
      <div class="sc-defense-box sc-defense-ac">
        <span class="sc-defense-value">{{ac}}</span>
        <span class="sc-defense-label">AC</span>
      </div>
      <div class="sc-defense-box sc-defense-tl">
        <span class="sc-defense-value">{{tl}}</span>
        <span class="sc-defense-label">TL</span>
      </div>
    </div>

    {{!-- Hull & Shield Bars --}}
    <div class="sc-sidebar-vitals">
      <div class="sc-vital sc-vital-hull">
        <div class="sc-vital-header">
          <span class="sc-vital-label">Hull</span>
          <span class="sc-vital-numbers">{{data.hull.current}} / {{data.hull.max}}</span>
        </div>
        <div class="sc-vital-bar">
          <div class="sc-vital-bar-fill" style="width:{{derived.hullPercent}}%"></div>
        </div>
        <div class="sc-vital-edit">
          <input type="number" data-field="hull.current" value="{{data.hull.current}}" />
          <span class="sc-sep">/</span>
          <input type="number" data-field="hull.max" value="{{data.hull.max}}" />
        </div>
      </div>
      <div class="sc-vital sc-vital-shield">
        <div class="sc-vital-header">
          <span class="sc-vital-label">Shields</span>
          <span class="sc-vital-numbers">{{data.shields.current}} / {{data.shields.max}}</span>
        </div>
        <div class="sc-vital-bar">
          <div class="sc-vital-bar-fill" style="width:{{derived.shieldPercent}}%"></div>
        </div>
        <div class="sc-vital-edit">
          <input type="number" data-field="shields.current" value="{{data.shields.current}}" />
          <span class="sc-sep">/</span>
          <input type="number" data-field="shields.max" value="{{data.shields.max}}" />
        </div>
      </div>
    </div>

    {{!-- Quick Stats --}}
    <div class="sc-sidebar-stats">
      <ul class="sc-sidebar-stats-list">
        <li><span class="sc-stat-label">Speed</span><span class="sc-stat-value">{{data.speed}}</span></li>
        <li><span class="sc-stat-label">Turn Dist.</span><span class="sc-stat-value">{{data.turnDistance}}</span></li>
        <li><span class="sc-stat-label">Tier</span><span class="sc-stat-value">{{data.tier}}</span></li>
        <li><span class="sc-stat-label">DT</span><span class="sc-stat-value">{{data.dt}}</span></li>
        <li><span class="sc-stat-label">CT</span><span class="sc-stat-value">{{data.ct}}</span></li>
      </ul>
    </div>

  </aside>

  {{!-- ─── MAIN CONTENT ───────────────────────────────────────────────── --}}
  <div class="sc-main">

    {{!-- Tab Navigation --}}
    <nav class="sc-nav">
      <button type="button" class="sc-tab active" data-sc-tab="stats"><i class="fa-solid fa-cog"></i> Stats</button>
      <button type="button" class="sc-tab" data-sc-tab="subsystems"><i class="fa-solid fa-microchip"></i> Systems</button>
      <button type="button" class="sc-tab" data-sc-tab="weapons"><i class="fa-solid fa-crosshairs"></i> Weapons</button>
      <button type="button" class="sc-tab" data-sc-tab="crew"><i class="fa-solid fa-users"></i> Crew</button>
      <button type="button" class="sc-tab" data-sc-tab="cargo"><i class="fa-solid fa-boxes-stacked"></i> Cargo</button>
    </nav>

    {{!-- Scrollable Body --}}
    <div class="sc-body">

      {{!-- ═══ STATS TAB ═══ --}}
      <div class="tab-pane active" data-sc-pane="stats">

        <header>
          <span>Frame &amp; Identity</span>
        </header>
        <div class="sc-form-grid">
          <div class="sc-field">
            <span class="sc-field-label">Frame</span>
            <div class="sc-field-inline">
              <select data-field="frame">{{#each frameOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
              <button type="button" data-action="applyFrame" class="sc-btn sc-btn-apply">Apply</button>
            </div>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Size</span>
            <select data-field="size">{{#each sizeOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Maneuverability</span>
            <select data-field="maneuverability">{{#each manOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Disposition</span>
            <select data-field="disposition">{{#each dispOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Tier</span>
            <input type="number" data-field="tier" value="{{data.tier}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Speed</span>
            <input type="number" data-field="speed" value="{{data.speed}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Turn Distance</span>
            <input type="number" data-field="turnDistance" value="{{data.turnDistance}}" />
          </div>
        </div>

        <header>
          <span>Hull &amp; Defenses</span>
        </header>
        <div class="sc-form-grid">
          <div class="sc-field">
            <span class="sc-field-label">Hull HP</span>
            <div class="sc-field-inline">
              <input type="number" data-field="hull.current" value="{{data.hull.current}}" />
              <span class="sc-sep">/</span>
              <input type="number" data-field="hull.max" value="{{data.hull.max}}" />
            </div>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Shield Points</span>
            <div class="sc-field-inline">
              <input type="number" data-field="shields.current" value="{{data.shields.current}}" />
              <span class="sc-sep">/</span>
              <input type="number" data-field="shields.max" value="{{data.shields.max}}" />
            </div>
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Damage Threshold</span>
            <input type="number" data-field="dt" value="{{data.dt}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Critical Threshold</span>
            <input type="number" data-field="ct" value="{{data.ct}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Armor (AC)</span>
            <input type="number" data-field="armorBonus" value="{{data.armorBonus}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Armor TL Pen.</span>
            <input type="number" data-field="armorTlPenalty" value="{{data.armorTlPenalty}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Countermeasures</span>
            <input type="number" data-field="countermeasuresBonus" value="{{data.countermeasuresBonus}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Pilot Ranks</span>
            <input type="number" data-field="pilotRanks" value="{{data.pilotRanks}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Computer Bonus</span>
            <input type="number" data-field="computerBonus" value="{{data.computerBonus}}" />
          </div>
          <div class="sc-field">
            <span class="sc-field-label">Cargo Capacity</span>
            <input type="number" data-field="cargoCapacity" value="{{data.cargoCapacity}}" />
          </div>
        </div>

        <header>
          <span>Notes</span>
        </header>
        <div class="sc-field" style="padding:6px 0;">
          <textarea data-field="notes" rows="3">{{data.notes}}</textarea>
        </div>

      </div>

      {{!-- ═══ SUBSYSTEMS TAB ═══ --}}
      <div class="tab-pane" data-sc-pane="subsystems">

        <header>
          <span>Ship Subsystems<span class="sc-header-count">{{subsystems.length}} installed</span></span>
        </header>
        <ol class="sc-directory-list">
          {{#each subsystems}}
          <li class="sc-subsystem-row sc-sev-{{this.severity}}">
            <i class="fas {{this.icon}}"></i>
            <span class="sc-sub-name">{{this.name}}</span>
            <span class="sc-sub-type">{{this.typeLabel}}</span>
            <select data-action="setCondition" data-subsystem-id="{{this.id}}">{{#each this.conditionOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
            <button type="button" data-action="removeSubsystem" data-subsystem-id="{{this.id}}" class="sc-btn-icon sc-danger"><i class="fas fa-trash"></i></button>
          </li>
          {{/each}}
          {{#unless subsystems.length}}<li class="sc-empty">No subsystems installed.</li>{{/unless}}
        </ol>

        <header>
          <span>Add Subsystem</span>
        </header>
        <div class="sc-add-row">
          <select data-subsystem-type-select>{{#each subsystemTypeOptions}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select>
          <input type="text" data-subsystem-name-input placeholder="Custom name (optional)" />
          <button type="button" data-action="addSubsystem" class="sc-btn sc-btn-add"><i class="fas fa-plus"></i> Add</button>
        </div>

      </div>

      {{!-- ═══ WEAPONS TAB ═══ --}}
      <div class="tab-pane" data-sc-pane="weapons">

        <header>
          <span>Equipped Weapons<span class="sc-header-count">{{weapons.length}} mounted</span></span>
        </header>
        <div class="sc-drop-zone" data-drop-zone="weapons">
          <ol class="sc-directory-list sc-weapon-list">
            {{#each weapons}}
            <li class="sc-weapon-row">
              <strong>{{this.name}}</strong>
              <span class="sc-wep-tag">{{this.damage}}</span>
              <span class="sc-wep-tag">{{this.mount}}</span>
              <span class="sc-wep-tag">{{this.arcLabel}}</span>
              <span class="sc-wep-tag">{{this.range}}</span>
              <span class="sc-wep-tag sc-wep-ammo">{{this.ammoLabel}}</span>
              <button type="button" data-action="removeWeapon" data-weapon-id="{{this.id}}" class="sc-btn-icon sc-danger"><i class="fas fa-trash"></i></button>
            </li>
            {{/each}}
            {{#unless weapons.length}}<li class="sc-empty">No weapons equipped. Drag from compendium or add below.</li>{{/unless}}
          </ol>
        </div>

        <header>
          <span>Add from Catalog</span>
        </header>
        <div class="sc-add-row">
          <select data-weapon-catalog-select>{{#each weaponCatalogOptions}}<option value="{{this.value}}">{{this.label}}</option>{{/each}}</select>
          <button type="button" data-action="addWeaponFromCatalog" class="sc-btn sc-btn-add"><i class="fas fa-plus"></i> Add</button>
        </div>

      </div>

      {{!-- ═══ CREW TAB ═══ --}}
      <div class="tab-pane" data-sc-pane="crew">

        <header>
          <span>Crew Assignments</span>
        </header>
        <p class="sc-hint">Assign PCs/NPCs to roles. Assignments are saved per ship.</p>

        {{#each roleAssignments}}
        <div class="sc-crew-block">
          <div class="sc-crew-header">
            <i class="fas {{this.icon}}"></i>
            <span>{{this.label}}</span>
            <div class="sc-crew-btns">
              <button type="button" data-action="addCrewSlot" data-role="{{this.id}}" class="sc-crew-plus" title="Add slot">+</button>
              {{#if this.canRemoveSlot}}<button type="button" data-action="removeCrewSlot" data-role="{{this.id}}" class="sc-crew-minus" title="Remove slot">−</button>{{/if}}
            </div>
          </div>
          <div class="sc-crew-selects {{#if this.needsScroll}}sc-crew-scroll{{/if}}">
            {{#each this.slots}}<select data-crew-role="{{../id}}">{{#each this.options}}<option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>{{/each}}</select>{{/each}}
          </div>
        </div>
        {{/each}}

        <header>
          <span>Ship Computer</span>
        </header>
        <div class="sc-crew-block">
          <div class="sc-crew-header">
            <i class="fas fa-microchip"></i>
            <span>Computer NPC</span>
          </div>
          <select data-computer-npc class="sc-full-select">{{#each computerNpcOptions}}<option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>{{/each}}</select>
        </div>

        <button type="button" data-action="saveCrew" class="sc-btn-full"><i class="fas fa-save"></i> Save Crew Assignments</button>

      </div>

      {{!-- ═══ CARGO TAB ═══ --}}
      <div class="tab-pane" data-sc-pane="cargo">

        <header>
          <span>Cargo Hold<span class="sc-header-count">{{cargoUsed}} / {{cargoCapacity}} bulk</span></span>
        </header>
        <div class="sc-drop-zone" data-drop-zone="cargo">
          <div class="sc-inv-table">
            <div class="sc-inv-header">
              <span class="sc-inv-col-name">Item</span>
              <span class="sc-inv-col-val">Value</span>
              <span class="sc-inv-col-qty">Qty</span>
              <span class="sc-inv-col-bulk">Bulk</span>
              <span class="sc-inv-col-act"></span>
            </div>
            {{#each inventory}}
            <div class="sc-inv-row">
              <span class="sc-inv-col-name"><img src="{{this.img}}" width="24" height="24" /><span>{{this.name}}</span></span>
              <span class="sc-inv-col-val">{{this.value}}</span>
              <span class="sc-inv-col-qty">{{this.quantity}}</span>
              <span class="sc-inv-col-bulk">{{this.bulk}}</span>
              <span class="sc-inv-col-act">
                {{#if this.isWeapon}}<button type="button" data-action="equipWeapon" data-item-id="{{this.id}}" class="sc-btn-icon sc-equip" title="Equip as ship weapon"><i class="fas fa-crosshairs"></i></button>{{/if}}
                <button type="button" data-action="removeInventoryItem" data-item-id="{{this.id}}" class="sc-btn-icon sc-danger" title="Remove"><i class="fas fa-trash"></i></button>
              </span>
            </div>
            {{/each}}
            {{#unless hasInventory}}
            <div class="sc-inv-empty"><i class="fas fa-boxes-stacked"></i><p>Drag items here from compendiums or the item sidebar</p></div>
            {{/unless}}
          </div>
        </div>

      </div>

    </div>{{!-- .sc-body --}}
  </div>{{!-- .sc-main --}}
</div>{{!-- .sc-gm-sheet --}}
