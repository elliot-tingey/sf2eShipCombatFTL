<div class="sc-panel">

  {{!-- ═══ TOP BAR: Round, Phase, Controls ═══ --}}
  <header class="sc-topbar">
    <div class="sc-round-info">
      <span class="sc-round-badge">RND {{round}}</span>
      <span class="sc-phase-label">{{phaseName}}</span>
      <span class="sc-range-badge" title="Engagement range">
        <i class="fas fa-arrows-left-right"></i> {{rangeLabel}}
      </span>
    </div>
    <div class="sc-topbar-controls">
      {{#if setupMode}}
        <button type="button" data-action="startCombat" class="sc-btn sc-btn-go" {{#unless canStart}}disabled{{/unless}}>
          <i class="fas fa-play"></i> Start Combat
        </button>
      {{else}}
        <button type="button" data-action="advancePhase" class="sc-btn sc-btn-phase">
          <i class="fas fa-forward-step"></i> Next Phase
        </button>
      {{/if}}
      <button type="button" data-action="endCombat" class="sc-btn sc-btn-danger">
        <i class="fas fa-xmark"></i> End
      </button>
    </div>
  </header>

  {{!-- ═══ SETUP MODE ═══ --}}
  {{#if setupMode}}
  <section class="sc-setup">
    <div class="sc-setup-column">
      <h3><i class="fas fa-rocket"></i> Player Ship</h3>
      <div class="sc-template-grid">
        {{#each playerTemplates}}
          <button type="button" data-action="selectPlayerShip" data-template="{{this.id}}"
                  class="sc-template-btn {{#if this.selected}}selected{{/if}}">
            <strong>{{this.name}}</strong>
            <span>Hull {{this.hull}} / Shield {{this.shield}} / Reactor {{this.reactor}}</span>
          </button>
        {{/each}}
      </div>
    </div>
    <div class="sc-setup-column">
      <h3><i class="fas fa-skull-crossbones"></i> Enemy Ship</h3>
      <div class="sc-template-grid">
        {{#each enemyTemplates}}
          <button type="button" data-action="selectEnemyShip" data-template="{{this.id}}"
                  class="sc-template-btn {{#if this.selected}}selected{{/if}}">
            <strong>{{this.name}}</strong>
            <span>Hull {{this.hull}} / Shield {{this.shield}} / Reactor {{this.reactor}}</span>
          </button>
        {{/each}}
      </div>
    </div>

    {{!-- Crew Assignment --}}
    <div class="sc-setup-crew">
      <h3><i class="fas fa-users"></i> Assign Crew (Optional)</h3>
      <div class="sc-crew-assign-grid">
        {{#each crewRoles}}
          <div class="sc-crew-assign-slot">
            <label><i class="fas {{this.icon}}"></i> {{this.label}}</label>
            <select data-action="assignCrew" data-role="{{this.id}}">
              <option value="">— GM Controlled —</option>
              {{#each ../actors}}
                <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
              {{/each}}
            </select>
          </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- ═══ COMBAT MODE ═══ --}}
  {{#unless setupMode}}
  <section class="sc-battlefield">

    {{!-- ─── Ship Displays ─── --}}
    <div class="sc-ships-row">

      {{!-- PLAYER SHIP --}}
      <div class="sc-ship sc-ship-player">
        <div class="sc-ship-header">
          <h3>{{playerShip.name}}</h3>
          <span class="sc-reactor-display" title="Reactor power: {{playerShip.usedPower}}/{{playerShip.reactor.total}}">
            <i class="fas fa-bolt"></i> {{playerShip.freePower}} free
          </span>
        </div>

        {{!-- Hull & Shield bars --}}
        <div class="sc-vitals">
          <div class="sc-vital-row">
            <span class="sc-vital-label">HULL</span>
            <div class="sc-bar sc-bar-hull">
              <div class="sc-bar-fill" style="width: {{playerShip.hullPercent}}%"></div>
            </div>
            <span class="sc-vital-num">{{playerShip.hull.current}}/{{playerShip.hull.max}}</span>
          </div>
          <div class="sc-vital-row">
            <span class="sc-vital-label">SHLD</span>
            <div class="sc-bar sc-bar-shield">
              <div class="sc-bar-fill" style="width: {{playerShip.shieldPercent}}%"></div>
            </div>
            <span class="sc-vital-num">{{playerShip.shields.current}}/{{playerShip.shields.max}}</span>
          </div>
        </div>

        {{!-- Systems Grid --}}
        <div class="sc-systems-grid">
          {{#each playerShip.systemsArray}}
            <div class="sc-system-room {{this.statusClass}}" data-system="{{this.id}}" data-ship="player" title="{{this.label}} — {{this.statusLabel}}">
              <div class="sc-sys-top">
                <i class="fas {{this.icon}}"></i>
                <span class="sc-sys-name">{{this.label}}</span>
                {{#each this.statusIcons}}
                  <span class="sc-status-icon">{{this}}</span>
                {{/each}}
              </div>
              <div class="sc-sys-hp-bar">
                <div class="sc-sys-hp-fill" style="width: {{this.hpPercent}}%; background: {{this.color}}"></div>
              </div>
              <div class="sc-sys-hp-text">{{this.hp}}/{{this.maxHp}}</div>
              <div class="sc-power-pips">
                {{#each this.pips}}
                  <span class="sc-pip {{#if this.filled}}filled{{/if}} {{#if this.overMax}}over-max{{/if}}"
                        data-action="adjustPower" data-system="{{../id}}" data-ship="player" data-level="{{this.level}}"
                        style="{{#if this.filled}}background: {{../color}}; box-shadow: 0 0 4px {{../color}}{{/if}}">
                  </span>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>

        {{!-- Weapons --}}
        <div class="sc-weapons-list">
          {{#each playerShip.weapons}}
            <div class="sc-weapon-tag" title="{{this.damage}} {{this.typeLabel}} damage, power cost {{this.powerCost}}{{this.ammoText}}">
              <span class="sc-weapon-type-dot" style="background: {{this.typeColor}}"></span>
              {{this.name}}
              {{#if this.hasAmmo}}<span class="sc-ammo">×{{this.ammo}}</span>{{/if}}
            </div>
          {{/each}}
        </div>
      </div>

      {{!-- VS DIVIDER --}}
      <div class="sc-vs-divider">
        <div class="sc-vs-text">VS</div>
        <div class="sc-range-display">
          <button type="button" data-action="noOp" class="sc-range-btn" title="Range changed by Pilot actions">
            {{rangeLabel}}
          </button>
        </div>
      </div>

      {{!-- ENEMY SHIP --}}
      <div class="sc-ship sc-ship-enemy">
        <div class="sc-ship-header">
          <h3>{{enemyShip.name}}</h3>
          {{#if enemyScanned}}
            <span class="sc-reactor-display">
              <i class="fas fa-bolt"></i> R:{{enemyShip.reactor.total}}
            </span>
          {{else}}
            <span class="sc-reactor-display sc-unknown">
              <i class="fas fa-question"></i> ???
            </span>
          {{/if}}
        </div>

        <div class="sc-vitals">
          <div class="sc-vital-row">
            <span class="sc-vital-label">HULL</span>
            <div class="sc-bar sc-bar-hull">
              <div class="sc-bar-fill" style="width: {{enemyShip.hullPercent}}%"></div>
            </div>
            <span class="sc-vital-num">{{enemyShip.hull.current}}/{{enemyShip.hull.max}}</span>
          </div>
          <div class="sc-vital-row">
            <span class="sc-vital-label">SHLD</span>
            <div class="sc-bar sc-bar-shield">
              <div class="sc-bar-fill" style="width: {{enemyShip.shieldPercent}}%"></div>
            </div>
            <span class="sc-vital-num">{{enemyShip.shields.current}}/{{enemyShip.shields.max}}</span>
          </div>
        </div>

        <div class="sc-systems-grid">
          {{#each enemyShip.systemsArray}}
            <div class="sc-system-room {{this.statusClass}} {{#unless ../enemyScanned}}sc-unscanned{{/unless}}"
                 data-system="{{this.id}}" data-ship="enemy">
              <div class="sc-sys-top">
                <i class="fas {{this.icon}}"></i>
                <span class="sc-sys-name">{{this.label}}</span>
                {{#each this.statusIcons}}
                  <span class="sc-status-icon">{{this}}</span>
                {{/each}}
              </div>
              {{#if ../enemyScanned}}
                <div class="sc-sys-hp-bar">
                  <div class="sc-sys-hp-fill" style="width: {{this.hpPercent}}%; background: {{this.color}}"></div>
                </div>
                <div class="sc-sys-hp-text">{{this.hp}}/{{this.maxHp}}</div>
                <div class="sc-power-pips">
                  {{#each this.pips}}
                    <span class="sc-pip {{#if this.filled}}filled{{/if}}" style="{{#if this.filled}}background: {{../color}}; box-shadow: 0 0 4px {{../color}}{{/if}}"></span>
                  {{/each}}
                </div>
              {{else}}
                <div class="sc-sys-hp-bar"><div class="sc-sys-hp-fill sc-unknown-fill" style="width: 100%"></div></div>
                <div class="sc-sys-hp-text">???</div>
              {{/if}}
            </div>
          {{/each}}
        </div>

        {{!-- Enemy Weapons --}}
        {{#if enemyScanned}}
        <div class="sc-weapons-list">
          {{#each enemyShip.weapons}}
            <div class="sc-weapon-tag">
              <span class="sc-weapon-type-dot" style="background: {{this.typeColor}}"></span>
              {{this.name}}
              {{#if this.hasAmmo}}<span class="sc-ammo">×{{this.ammo}}</span>{{/if}}
            </div>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- ─── Action Panel ─── --}}
    <div class="sc-action-panel">

      {{!-- Role Tabs --}}
      <div class="sc-role-tabs">
        {{#each roles}}
          <button type="button" data-action="selectRole" data-role="{{this.id}}"
                  class="sc-role-tab {{#if this.active}}active{{/if}} {{#if this.acted}}acted{{/if}} {{#if this.phaseMatch}}phase-match{{/if}}">
            <i class="fas {{this.icon}}"></i>
            <span>{{this.label}}</span>
            {{#if this.acted}}<i class="fas fa-check sc-acted-check"></i>{{/if}}
          </button>
        {{/each}}
      </div>

      {{!-- Action Buttons --}}
      <div class="sc-actions-row">
        {{#each currentActions}}
          <button type="button" data-action="selectAction" data-action-id="{{this.id}}"
                  class="sc-action-btn {{#if this.selected}}selected{{/if}}" title="{{this.description}}">
            <strong>{{this.name}}</strong>
            <span class="sc-action-desc">{{this.shortDesc}}</span>
          </button>
        {{/each}}
      </div>

      {{!-- Options Row: Target System, Weapon Selection, Range --}}
      {{#if showOptions}}
      <div class="sc-options-row">
        {{#if showTargetSystem}}
          <div class="sc-option-group">
            <label>Target System</label>
            <select data-action="setTarget" class="sc-select">
              {{#each targetSystems}}
                <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}} {{this.hpText}}</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        {{#if showWeaponSelect}}
          <div class="sc-option-group">
            <label>Weapon</label>
            <select data-action="setWeapon" class="sc-select">
              {{#each weaponOptions}}
                <option value="{{this.index}}" {{#if this.selected}}selected{{/if}}>
                  {{this.name}} ({{this.damage}} {{this.typeLabel}}) {{this.ammoText}}
                </option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        {{#if showRangeSelect}}
          <div class="sc-option-group">
            <label>Target Range</label>
            <select data-action="setRange" class="sc-select">
              <option value="close" {{#if rangeClose}}selected{{/if}}>Close</option>
              <option value="medium" {{#if rangeMedium}}selected{{/if}}>Medium</option>
              <option value="long" {{#if rangeLong}}selected{{/if}}>Long</option>
            </select>
          </div>
        {{/if}}
        {{#if showSkillMod}}
          <div class="sc-option-group">
            <label>Skill Modifier</label>
            <input type="number" data-action="setSkillMod" class="sc-input-num" value="{{skillMod}}" />
          </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Execute Button --}}
      {{#if showExecute}}
      <div class="sc-execute-row">
        <button type="button" data-action="executeAction" class="sc-btn sc-btn-execute" {{#if roleActed}}disabled title="This role has already acted this round"{{/if}}>
          <i class="fas fa-dice-d20"></i> Execute {{selectedActionName}}
        </button>
      </div>
      {{/if}}
    </div>

    {{!-- ─── GM Tools ─── --}}
    {{#if isGM}}
    <div class="sc-gm-tools">
      <span class="sc-gm-label"><i class="fas fa-crown"></i> GM</span>
      <button type="button" data-action="gmEnemyAttack" class="sc-btn sc-btn-gm">
        <i class="fas fa-skull-crossbones"></i> Enemy Attack
      </button>
      <button type="button" data-action="gmDamage" class="sc-btn sc-btn-gm">
        <i class="fas fa-burst"></i> Apply Damage
      </button>
    </div>
    {{/if}}

    {{!-- ─── Combat Log ─── --}}
    <div class="sc-log">
      <div class="sc-log-header">
        <i class="fas fa-scroll"></i> Combat Log
        <button type="button" data-action="clearLog" class="sc-log-clear" title="Clear log"><i class="fas fa-eraser"></i></button>
      </div>
      <div class="sc-log-entries">
        {{#each log}}
          <div class="sc-log-entry">› {{this}}</div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/unless}}
</div>
