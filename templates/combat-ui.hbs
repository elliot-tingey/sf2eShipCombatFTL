<div class="sc-panel">

  {{!-- ═══ TOP BAR ═══ --}}
  <header class="sc-topbar">
    <div class="sc-round-info">
      <span class="sc-round-badge">RND {{round}}</span>
      <span class="sc-status-text">{{statusText}}</span>
    </div>
    <div class="sc-topbar-controls">
      {{#if setupMode}}
        <button type="button" data-action="startCombat" class="sc-btn sc-btn-go" {{#unless canStart}}disabled{{/unless}}>
          <i class="fas fa-play"></i> Start Combat
        </button>
      {{else}}
        <button type="button" data-action="endRound" class="sc-btn sc-btn-phase">
          <i class="fas fa-forward-step"></i> End Round
        </button>
      {{/if}}
      <button type="button" data-action="endCombat" class="sc-btn sc-btn-danger">
        <i class="fas fa-xmark"></i> End
      </button>
    </div>
  </header>

  {{!-- ═══ SETUP MODE ═══ --}}
  {{#if setupMode}}
  <section class="sc-setup">
    <div class="sc-setup-info">
      <p>Add Starship actors to the combat encounter. Create Starship actors via the Actor directory (type: starship).</p>
    </div>
    <div class="sc-setup-ships">
      <h3>Available Ships</h3>
      <div class="sc-setup-ship-list">
        {{#each availableShips}}
          <div class="sc-setup-ship-row">
            <img src="{{this.img}}" width="28" height="28" />
            <span class="sc-setup-ship-name">{{this.name}}</span>
            <span class="sc-setup-ship-disp sc-disp-{{this.disposition}}">{{this.disposition}}</span>
            {{#if this.added}}
              <button type="button" data-action="removeShip" data-actor-id="{{this.id}}" class="sc-btn sc-btn-sm sc-btn-danger">Remove</button>
            {{else}}
              <button type="button" data-action="addShip" data-actor-id="{{this.id}}" class="sc-btn sc-btn-sm sc-btn-go">Add</button>
            {{/if}}
          </div>
        {{/each}}
        {{#unless availableShips.length}}
          <p class="sc-empty-note">No Starship actors found. Create one via the Actor directory (type: starship).</p>
        {{/unless}}
      </div>
    </div>

    {{!-- Crew Assignment --}}
    {{#if addedShips.length}}
    <div class="sc-setup-crew">
      <h3>Crew Assignments</h3>
      {{#each addedShips}}
        <div class="sc-crew-ship-block">
          <h4>{{this.name}} ({{this.disposition}})</h4>
          <div class="sc-crew-assign-grid">
            {{#each ../crewRoles}}
              <div class="sc-crew-assign-slot">
                <label><i class="fas {{this.icon}}"></i> {{this.label}}</label>
                <select data-action="assignCrew" data-ship-id="{{../this.id}}" data-role="{{this.id}}">
                  <option value="">— None —</option>
                  {{#each ../../pcActors}}
                    <option value="{{this.id}}">{{this.name}}</option>
                  {{/each}}
                </select>
              </div>
            {{/each}}
          </div>
        </div>
      {{/each}}
    </div>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ═══ COMBAT MODE ═══ --}}
  {{#unless setupMode}}
  <section class="sc-battlefield">

    {{!-- ─── Ship Cards ─── --}}
    <div class="sc-ships-scroll">
      {{#each ships}}
        <div class="sc-ship-card sc-disp-{{this.disposition}} {{#if this.destroyed}}sc-destroyed{{/if}} {{#if this.selected}}sc-selected{{/if}}"
             data-action="selectShip" data-ship-id="{{this.id}}">
          <div class="sc-ship-card-header">
            <strong>{{this.name}}</strong>
            <span class="sc-ship-card-init" title="Initiative">⚡{{this.initiative}}</span>
          </div>
          <div class="sc-ship-card-stats">
            <span>AC {{this.ac}} | TL {{this.tl}}</span>
          </div>
          <div class="sc-ship-card-bars">
            <div class="sc-bar sc-bar-hull" title="Hull {{this.hull.current}}/{{this.hull.max}}">
              <div class="sc-bar-fill" style="width:{{this.hullPercent}}%"></div>
            </div>
            <div class="sc-bar sc-bar-shield" title="Shields {{this.shieldsTotal}}/{{this.shieldsMax}}">
              <div class="sc-bar-fill" style="width:{{this.shieldPercent}}%"></div>
            </div>
          </div>
          <div class="sc-ship-card-nums">
            Hull {{this.hull.current}}/{{this.hull.max}} | SP {{this.shieldsTotal}}
          </div>
          {{#if this.destroyed}}<div class="sc-destroyed-overlay">DESTROYED</div>{{/if}}
        </div>
      {{/each}}
    </div>

    {{!-- ─── Selected Ship Detail ─── --}}
    {{#if selectedShip}}
    <div class="sc-detail-row">
      <div class="sc-detail-left">
        {{!-- Shield Quadrants --}}
        <div class="sc-shield-display">
          <div class="sc-shield-label">Shields: {{selectedShip.name}}</div>
          <div class="sc-shield-cross">
            <div class="sc-shield-q sc-sq-fwd" title="Forward: {{selectedShip.shields.forward.current}}/{{selectedShip.shields.forward.max}}">
              <span>FWD</span>
              <strong>{{selectedShip.shields.forward.current}}</strong>
            </div>
            <div class="sc-shield-q sc-sq-port" title="Port: {{selectedShip.shields.port.current}}/{{selectedShip.shields.port.max}}">
              <span>PRT</span>
              <strong>{{selectedShip.shields.port.current}}</strong>
            </div>
            <div class="sc-shield-center">⬡</div>
            <div class="sc-shield-q sc-sq-stbd" title="Starboard: {{selectedShip.shields.starboard.current}}/{{selectedShip.shields.starboard.max}}">
              <span>STB</span>
              <strong>{{selectedShip.shields.starboard.current}}</strong>
            </div>
            <div class="sc-shield-q sc-sq-aft" title="Aft: {{selectedShip.shields.aft.current}}/{{selectedShip.shields.aft.max}}">
              <span>AFT</span>
              <strong>{{selectedShip.shields.aft.current}}</strong>
            </div>
          </div>
        </div>

        {{!-- Subsystems --}}
        <div class="sc-subsystems">
          <div class="sc-subsys-label">Subsystems</div>
          {{#each selectedShip.criticals}}
            <div class="sc-subsys-entry sc-crit-sev-{{this.severity}}">
              <i class="fas {{this.icon}}"></i>
              <span>{{this.label}}</span>
              <span class="sc-subsys-cond">{{this.conditionLabel}}</span>
            </div>
          {{/each}}
        </div>
      </div>

      <div class="sc-detail-right">
        {{!-- Weapons --}}
        <div class="sc-weapons-detail">
          <div class="sc-weapons-label">Weapons</div>
          {{#each selectedShip.weapons}}
            <div class="sc-weapon-detail-row">
              <span class="sc-weapon-type-badge sc-wtype-{{this.type}}">{{this.typeLabel}}</span>
              <strong>{{this.name}}</strong>
              <span class="sc-weapon-dmg">{{this.damage}}</span>
              <span class="sc-weapon-arc">{{this.arcLabel}}</span>
            </div>
          {{/each}}
          {{#unless selectedShip.weapons.length}}
            <div class="sc-empty-note">No weapons</div>
          {{/unless}}
        </div>

        {{!-- Tracking Projectiles --}}
        {{#if trackingProjectiles.length}}
        <div class="sc-tracking-display">
          <div class="sc-tracking-label"><i class="fas fa-rocket"></i> Tracking Weapons</div>
          {{#each trackingProjectiles}}
            <div class="sc-tracking-entry sc-track-{{this.trackingClass}}">
              <span class="sc-track-icon">{{this.speedIcon}}</span>
              <span>{{this.weaponName}}</span>
              <span class="sc-track-source">{{this.sourceName}} → {{this.targetName}}</span>
              <span class="sc-track-eta">{{this.turnsRemaining}} turn(s)</span>
            </div>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ─── Action Panel ─── --}}
    <div class="sc-action-panel">
      {{!-- Crew / Role Selection --}}
      <div class="sc-action-header">
        <div class="sc-role-tabs">
          {{#each roles}}
            <button type="button" data-action="selectRole" data-role="{{this.id}}"
                    class="sc-role-tab {{#if this.active}}active{{/if}}">
              <i class="fas {{this.icon}}"></i> {{this.label}}
            </button>
          {{/each}}
        </div>
        <div class="sc-crew-selector">
          <label>Acting as:</label>
          <select data-action="selectCrew" class="sc-select">
            <option value="">— Select Crew —</option>
            {{#each currentRoleCrew}}
              <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
                {{this.name}} {{#if this.acted}}(done){{/if}}
              </option>
            {{/each}}
          </select>
          <button type="button" data-action="skipTurn" class="sc-btn sc-btn-sm" title="Skip this crew member's turn">
            <i class="fas fa-forward"></i> Skip
          </button>
        </div>
      </div>

      {{!-- Action Buttons --}}
      <div class="sc-actions-grid">
        {{#each currentActions}}
          <button type="button" data-action="selectAction" data-action-id="{{this.id}}"
                  class="sc-action-btn {{#if this.selected}}selected{{/if}} {{#if this.isFreeAction}}sc-free-action{{/if}}"
                  title="{{this.description}}">
            <strong>{{this.name}}</strong>
            {{#if this.isFreeAction}}<span class="sc-free-badge">FREE</span>{{/if}}
            <span class="sc-action-desc">{{this.shortDesc}}</span>
          </button>
        {{/each}}
      </div>

      {{!-- Options --}}
      {{#if showOptions}}
      <div class="sc-options-row">
        {{#if showTargetShip}}
          <div class="sc-option-group">
            <label>Target Ship</label>
            <select data-action="setTargetShip" class="sc-select">
              {{#each targetShips}}
                <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        {{#if showWeapon}}
          <div class="sc-option-group">
            <label>Weapon</label>
            <select data-action="setWeapon" class="sc-select">
              {{#each weaponOptions}}
                <option value="{{this.index}}" {{#if this.selected}}selected{{/if}}>{{this.name}} ({{this.damage}} {{this.typeLabel}})</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        {{#if showQuadrant}}
          <div class="sc-option-group">
            <label>Target Quadrant</label>
            <select data-action="setQuadrant" class="sc-select">
              <option value="forward">Forward</option>
              <option value="port">Port</option>
              <option value="starboard">Starboard</option>
              <option value="aft">Aft</option>
            </select>
          </div>
        {{/if}}
        {{#if showSubsystem}}
          <div class="sc-option-group">
            <label>Target Subsystem</label>
            <select data-action="setSubsystem" class="sc-select">
              <option value="">— Hull Only —</option>
              {{#each subsystemOptions}}
                <option value="{{this.id}}">{{this.label}} ({{this.condition}})</option>
              {{/each}}
            </select>
            {{#unless canTargetSubsystem}}<span class="sc-option-warn">Requires scan!</span>{{/unless}}
          </div>
        {{/if}}
        {{#if showSystemChoice}}
          <div class="sc-option-group">
            <label>System</label>
            <select data-action="setSubsystem" class="sc-select">
              {{#each ownSubsystems}}
                <option value="{{this.id}}">{{this.label}} ({{this.condition}})</option>
              {{/each}}
            </select>
          </div>
        {{/if}}
        <div class="sc-option-group">
          <label>Skill Mod</label>
          <input type="number" data-action="setSkillMod" class="sc-input-num" value="{{skillMod}}" />
        </div>
      </div>
      {{/if}}

      {{!-- Execute --}}
      {{#if showExecute}}
      <div class="sc-execute-row">
        <button type="button" data-action="executeAction" class="sc-btn sc-btn-execute" {{#if crewActed}}disabled title="Already acted"{{/if}}>
          <i class="fas fa-dice-d20"></i> Execute: {{selectedActionName}}
        </button>
      </div>
      {{/if}}
    </div>

    {{!-- ─── Combat Log ─── --}}
    <div class="sc-log">
      <div class="sc-log-header">
        <i class="fas fa-scroll"></i> Combat Log
        <button type="button" data-action="clearLog" class="sc-log-clear"><i class="fas fa-eraser"></i></button>
      </div>
      <div class="sc-log-entries">
        {{#each log}}
          <div class="sc-log-entry">› {{this}}</div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/unless}}
</div>
