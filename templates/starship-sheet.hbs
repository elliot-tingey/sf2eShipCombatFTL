<div class="sc-sheet">
  <header class="sc-sheet-header">
    <img class="sc-sheet-portrait" src="{{img}}" alt="{{name}}" />
    <div class="sc-sheet-title">
      <h1 contenteditable="true" data-field="name">{{name}}</h1>
      <div class="sc-sheet-stats-row">
        <span class="sc-stat-badge">AC <strong>{{ac}}</strong></span>
        <span class="sc-stat-badge">TL <strong>{{tl}}</strong></span>
        <span class="sc-stat-badge sc-hull-badge">Hull <strong>{{system.hull.current}}/{{system.hull.max}}</strong></span>
        <span class="sc-stat-badge sc-shield-badge">Shields <strong>{{totalShields}}/{{maxShields}}</strong></span>
      </div>
    </div>
  </header>

  <div class="sc-sheet-body">

    {{!-- Core Stats --}}
    <section class="sc-sheet-section">
      <h2>Core Stats</h2>
      <div class="sc-form-grid">
        <div class="sc-form-row">
          <label>Frame</label>
          <select name="system.frame">{{#each frameOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
        </div>
        <div class="sc-form-row">
          <label>Size</label>
          <select name="system.size">{{#each sizeOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
        </div>
        <div class="sc-form-row">
          <label>Maneuverability</label>
          <select name="system.maneuverability">{{#each maneuverabilityOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
        </div>
        <div class="sc-form-row">
          <label>Tier</label>
          <input type="number" name="system.tier" value="{{system.tier}}" />
        </div>
        <div class="sc-form-row">
          <label>Speed</label>
          <input type="number" name="system.speed" value="{{system.speed}}" />
        </div>
        <div class="sc-form-row">
          <label>Turn Distance</label>
          <input type="number" name="system.turnDistance" value="{{system.turnDistance}}" />
        </div>
        <div class="sc-form-row">
          <label>Disposition</label>
          <select name="system.disposition">{{#each dispositionOptions}}<option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>{{/each}}</select>
        </div>
      </div>
    </section>

    {{!-- Hull & Defenses --}}
    <section class="sc-sheet-section">
      <h2>Hull & Defenses</h2>
      <div class="sc-form-grid">
        <div class="sc-form-row">
          <label>Hull HP</label>
          <input type="number" name="system.hull.current" value="{{system.hull.current}}" style="width:60px" /> /
          <input type="number" name="system.hull.max" value="{{system.hull.max}}" style="width:60px" />
        </div>
        <div class="sc-form-row">
          <label>DT / CT</label>
          <input type="number" name="system.dt" value="{{system.dt}}" style="width:50px" /> /
          <input type="number" name="system.ct" value="{{system.ct}}" style="width:50px" />
        </div>
        <div class="sc-form-row">
          <label>Armor Bonus (AC)</label>
          <input type="number" name="system.armorBonus" value="{{system.armorBonus}}" />
        </div>
        <div class="sc-form-row">
          <label>Armor TL Penalty</label>
          <input type="number" name="system.armorTlPenalty" value="{{system.armorTlPenalty}}" />
        </div>
        <div class="sc-form-row">
          <label>Countermeasures (TL)</label>
          <input type="number" name="system.countermeasuresBonus" value="{{system.countermeasuresBonus}}" />
        </div>
        <div class="sc-form-row">
          <label>Pilot Ranks</label>
          <input type="number" name="system.pilotRanks" value="{{system.pilotRanks}}" />
        </div>
        <div class="sc-form-row">
          <label>Computer Bonus</label>
          <input type="number" name="system.computerBonus" value="{{system.computerBonus}}" />
        </div>
      </div>
    </section>

    {{!-- Shields --}}
    <section class="sc-sheet-section">
      <h2>Shields (Total SP: {{system.shields.total}})</h2>
      <div class="sc-shields-grid">
        {{#each shieldQuadrants}}
          <div class="sc-shield-quadrant">
            <label>{{this.label}}</label>
            <div class="sc-bar sc-bar-shield"><div class="sc-bar-fill" style="width:{{this.percent}}%"></div></div>
            <input type="number" name="system.shields.{{this.id}}.current" value="{{this.current}}" style="width:50px" /> /
            <input type="number" name="system.shields.{{this.id}}.max" value="{{this.max}}" style="width:50px" />
          </div>
        {{/each}}
      </div>
    </section>

    {{!-- Critical Systems --}}
    <section class="sc-sheet-section">
      <h2>Subsystems</h2>
      <div class="sc-crits-grid">
        {{#each criticalSystems}}
          <div class="sc-crit-entry sc-crit-sev-{{this.severity}}">
            <i class="fas {{this.icon}}"></i>
            <span class="sc-crit-name">{{this.label}}</span>
            <span class="sc-crit-condition">{{this.conditionLabel}}</span>
          </div>
        {{/each}}
      </div>
    </section>

    {{!-- Weapons --}}
    <section class="sc-sheet-section">
      <h2>Weapons</h2>
      {{#each weapons}}
        <div class="sc-weapon-entry">
          <strong>{{this.name}}</strong>
          <span class="sc-weapon-detail">{{this.type}} | {{this.mount}} | {{this.arc}} | {{this.damage}} | Range: {{this.range}}</span>
        </div>
      {{/each}}
      {{#unless weapons.length}}
        <p class="sc-empty-note">No weapons installed.</p>
      {{/unless}}
    </section>

    {{!-- Notes --}}
    <section class="sc-sheet-section">
      <h2>Notes</h2>
      <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
    </section>
  </div>
</div>
