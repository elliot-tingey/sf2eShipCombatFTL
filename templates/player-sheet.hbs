<div class="sc-player-sheet">
  <header class="sc-header">
    <img class="sc-portrait" src="{{img}}" />
    <div class="sc-header-info">
      <h1>{{name}}</h1>
      <div class="sc-derived-row">
        <span class="sc-derived">AC <strong>{{ac}}</strong></span>
        <span class="sc-derived">TL <strong>{{tl}}</strong></span>
        <span class="sc-derived">Speed <strong>{{speed}}</strong></span>
      </div>
    </div>
  </header>

  {{!-- Status Bars --}}
  <div class="sc-status-bars">
    <div class="sc-bar-group">
      <label>Hull {{hullCurrent}}/{{hullMax}}</label>
      <div class="sc-bar sc-bar-hull"><div class="sc-bar-fill" style="width:{{hullPercent}}%"></div></div>
    </div>
    <div class="sc-bar-group">
      <label>Shields {{shieldCurrent}}/{{shieldMax}}</label>
      <div class="sc-bar sc-bar-shield"><div class="sc-bar-fill" style="width:{{shieldPercent}}%"></div></div>
    </div>
  </div>

  <nav class="sheet-tabs sc-tabs" data-group="primary">
    <a class="item active" data-tab="overview" data-group="primary">Overview</a>
    {{#each roles}}
      <a class="item" data-tab="role-{{this.id}}" data-group="primary"><i class="fas {{this.icon}}"></i> {{this.label}}</a>
    {{/each}}
    <a class="item" data-tab="cargo" data-group="primary"><i class="fas fa-boxes-stacked"></i> Cargo</a>
  </nav>

  <div class="sc-player-body">

    {{!-- Overview Tab --}}
    <div class="tab active" data-tab="overview" data-group="primary">
      <div class="sc-overview-grid">
        <div class="sc-overview-col">
          <h3>Subsystems</h3>
          {{#each subsystems}}
            <div class="sc-sub-status sc-sev-{{this.severity}}">
              <i class="fas {{this.icon}}"></i>
              <span>{{this.name}}</span>
              <span class="sc-sub-cond">{{this.conditionLabel}}</span>
            </div>
          {{/each}}
        </div>
        <div class="sc-overview-col">
          <h3>Weapons</h3>
          {{#each weapons}}
            <div class="sc-wep-status">
              <strong>{{this.name}}</strong>
              <span>{{this.damage}} · {{this.arcLabel}} · {{this.range}}</span>
            </div>
          {{/each}}
          {{#unless weapons.length}}<p class="sc-empty">No weapons</p>{{/unless}}
        </div>
      </div>
      {{#if notes}}<div class="sc-notes-box"><h3>Notes</h3><div>{{{notes}}}</div></div>{{/if}}
    </div>

    {{!-- Role Tabs (placeholder content — actions come from combat UI) --}}
    {{#each roles}}
      <div class="tab" data-tab="role-{{this.id}}" data-group="primary">
        <div class="sc-role-page">
          <h2><i class="fas {{this.icon}}"></i> {{this.label}}</h2>
          <p class="sc-hint">Actions for this role are available during starship combat. Open the combat panel (🚀 in token controls) to take actions.</p>
        </div>
      </div>
    {{/each}}

    {{!-- Cargo Tab --}}
    <div class="tab" data-tab="cargo" data-group="primary">
      <div class="sc-cargo-page">
        <h2><i class="fas fa-boxes-stacked"></i> Cargo Hold</h2>
        <p class="sc-hint">Drag and drop items from compendiums or the item directory to add them to the ship's cargo.</p>
        <div class="sc-cargo-list">
          <p class="sc-empty">Cargo inventory coming soon — use the actor's native inventory tab for now.</p>
        </div>
      </div>
    </div>
  </div>
</div>
